{
  "name": "code-shelf",
  "displayName": "Code Shelf",
  "description": "IntelliJ-style Shelve Changes for VS Code — selectively shelve and restore code changes without git stash",
  "version": "1.3.1",
  "publisher": "EternalAcademy",
  "license": "MIT",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "keywords": [
    "shelve",
    "shelf",
    "stash",
    "intellij",
    "changes",
    "patch",
    "git",
    "source control"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/eternalacademy/code-shelf"
  },
  "bugs": {
    "url": "https://github.com/eternalacademy/code-shelf/issues"
  },
  "homepage": "https://github.com/eternalacademy/code-shelf#readme",
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "qna": "marketplace",
  "badges": [],
  "maintainers": [
    {
      "name": "Umesh Saini",
      "url": "https://github.com/umeshsaini17"
    }
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile",
    "test": "npm run compile && node out/test/shelf.test.js"
  },
  "devDependencies": {
    "@types/node": "18.x",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.9.1",
    "sharp": "^0.34.5",
    "typescript": "^5.3.0"
  },
  "contributes": {
    "commands": [
      {
        "command": "code-shelf.shelveChanges",
        "title": "Shelve Changes",
        "category": "Code Shelf",
        "icon": "$(archive)"
      },
      {
        "command": "code-shelf.silentShelve",
        "title": "Silent Shelve (All Changes)",
        "category": "Code Shelf",
        "icon": "$(zap)"
      },
      {
        "command": "code-shelf.shelveStaged",
        "title": "Shelve Staged Changes",
        "category": "Code Shelf",
        "icon": "$(git-commit)"
      },
      {
        "command": "code-shelf.shelveFile",
        "title": "Shelve This File",
        "category": "Code Shelf"
      },
      {
        "command": "code-shelf.unshelve",
        "title": "Unshelve",
        "category": "Code Shelf",
        "icon": "$(arrow-up)"
      },
      {
        "command": "code-shelf.unshelveFile",
        "title": "Unshelve This File",
        "category": "Code Shelf"
      },
      {
        "command": "code-shelf.deleteShelf",
        "title": "Delete Shelf",
        "category": "Code Shelf"
      },
      {
        "command": "code-shelf.renameShelf",
        "title": "Rename Shelf",
        "category": "Code Shelf"
      },
      {
        "command": "code-shelf.viewShelfDiff",
        "title": "View Shelf Diff",
        "category": "Code Shelf"
      },
      {
        "command": "code-shelf.refresh",
        "title": "Refresh Shelves",
        "category": "Code Shelf",
        "icon": "$(refresh)"
      }
    ],
    "views": {
      "scm": [
        {
          "id": "code-shelf-view",
          "name": "Code Shelf",
          "when": "config.code-shelf.enabled"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "code-shelf-view",
        "contents": "No shelves yet.\n[Shelve Changes](command:code-shelf.shelveChanges)\n[Silent Shelve](command:code-shelf.silentShelve)\n[Shelve Staged](command:code-shelf.shelveStaged)"
      }
    ],
    "menus": {
      "scm/title": [
        {
          "command": "code-shelf.shelveChanges",
          "group": "navigation@1"
        },
        {
          "command": "code-shelf.shelveStaged",
          "group": "navigation@2"
        },
        {
          "command": "code-shelf.silentShelve",
          "group": "navigation@3"
        }
      ],
      "scm/resourceGroup/context": [
        {
          "command": "code-shelf.shelveChanges",
          "group": "shelf@1"
        },
        {
          "command": "code-shelf.shelveStaged",
          "when": "scmResourceGroup == index",
          "group": "shelf@2"
        }
      ],
      "scm/resourceState/context": [
        {
          "command": "code-shelf.shelveFile",
          "group": "shelf@1"
        }
      ],
      "view/title": [
        {
          "command": "code-shelf.refresh",
          "when": "view == code-shelf-view",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "code-shelf.unshelve",
          "when": "view == code-shelf-view && viewItem == shelf",
          "group": "inline@1"
        },
        {
          "command": "code-shelf.renameShelf",
          "when": "view == code-shelf-view && viewItem == shelf",
          "group": "shelf@1"
        },
        {
          "command": "code-shelf.deleteShelf",
          "when": "view == code-shelf-view && viewItem == shelf",
          "group": "shelf@2"
        },
        {
          "command": "code-shelf.unshelveFile",
          "when": "view == code-shelf-view && viewItem == shelfFile",
          "group": "shelfFile@1"
        },
        {
          "command": "code-shelf.viewShelfDiff",
          "when": "view == code-shelf-view && viewItem == shelfFile",
          "group": "inline@1"
        }
      ]
    },
    "configuration": {
      "title": "Code Shelf",
      "properties": {
        "code-shelf.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Code Shelf extension"
        }
      }
    }
  }
}
