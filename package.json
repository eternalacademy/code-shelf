{
  "name": "code-shelf",
  "displayName": "Code Shelf",
  "description": "IntelliJ-style Shelve Changes for VS Code — selectively shelve and restore code changes without git stash",
  "version": "1.1.0",
  "publisher": "EternalAcademy",
  "license": "MIT",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "keywords": [
    "shelve",
    "shelf",
    "stash",
    "intellij",
    "changes",
    "patch",
    "git",
    "source control"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/eternalacademy/code-shelf"
  },
  "bugs": {
    "url": "https://github.com/eternalacademy/code-shelf/issues"
  },
  "homepage": "https://github.com/eternalacademy/code-shelf#readme",
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "qna": "marketplace",
  "badges": [],
  "maintainers": [
    {
      "name": "Umesh Saini",
      "url": "https://github.com/umeshsaini17"
    }
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile",
    "test": "npm run compile && node out/test/shelf.test.js"
  },
  "devDependencies": {
    "@types/node": "18.x",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.9.1",
    "sharp": "^0.34.5",
    "typescript": "^5.3.0"
  },
  "contributes": {
    "commands": [
      {
        "command": "code-shelf.shelveChanges",
        "title": "Code Shelf: Shelve Changes",
        "category": "Code Shelf"
      },
      {
        "command": "code-shelf.silentShelve",
        "title": "Code Shelf: Silent Shelve",
        "category": "Code Shelf"
      },
      {
        "command": "code-shelf.unshelve",
        "title": "Code Shelf: Unshelve",
        "category": "Code Shelf"
      },
      {
        "command": "code-shelf.deleteShelf",
        "title": "Code Shelf: Delete Shelf",
        "category": "Code Shelf"
      },
      {
        "command": "code-shelf.viewShelfDiff",
        "title": "Code Shelf: View Shelf Diff",
        "category": "Code Shelf"
      }
    ],
    "views": {
      "scm": [
        {
          "id": "code-shelf-view",
          "name": "Code Shelf",
          "when": "config.code-shelf.enabled"
        }
      ]
    },
    "menus": {
      "scm/title": [
        {
          "command": "code-shelf.shelveChanges",
          "group": "Code Shelf@1"
        },
        {
          "command": "code-shelf.silentShelve",
          "group": "Code Shelf@2"
        },
        {
          "command": "code-shelf.unshelve",
          "group": "Code Shelf@3"
        }
      ]
    },
    "configuration": {
      "title": "Code Shelf",
      "properties": {
        "code-shelf.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Code Shelf extension"
        },
        "code-shelf.shelfDirectory": {
          "type": "string",
          "default": ".vscode/shelf",
          "description": "Directory to store shelf files"
        }
      }
    }
  }
}
